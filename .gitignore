# Exclude raw VM data, python dependencies, and logs to ensure a zero-fat extraction
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.env
.venv/
conda/
miniconda/
docker/
*.log
*.sqlite
*.db
/tmp/

# -------------------------
# LoRA Pipeline Exclusions
# -------------------------
# Do NOT commit raw datasets or model weights
*.safetensors
*.bin
*.pt
*.pth
*.jsonl
# Hugging Face cache
.huggingface/
.cache/huggingface/
# LoRA Adapter output directories
lora_adapters*/
checkpoint-*/
